<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProyectoEmpresa.MainPage">
    
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#608EB4" Offset="4" />
            <GradientStop Color="#17183B" Offset="0.5" />
            <GradientStop Color="#1B3864" Offset="5.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Margin="0">
            <!-- Barra horizontal opciones rapidas -->
            <Grid HorizontalOptions="End" ColumnDefinitions="*,*,*" >

            </Grid>

            <!-- Barra horizontal ventanas -->
            <Grid ColumnDefinitions="*,*,*" RowDefinitions="*,*" HorizontalOptions="Center">
                <Image 
                    Source="logo.png" 
                    Grid.Column="1" 
                    Grid.Row="0" 
                    Aspect="AspectFit"
                    WidthRequest="400"
                    HeightRequest="200"
                    />

                <Button
                    Margin="10"
                    Grid.Row="1"
                    Grid.Column="0"
                    WidthRequest="250"
                    HeightRequest="NaN"
                    Opacity="10"
                    Text="Inventario&#x0a;Disponible"
                    Clicked="OnIrAVentana1Clicked"/>

                <Button
                    Margin="10"
                    Grid.Row="1"
                    Grid.Column="1"
                    WidthRequest="250"
                    HeightRequest="NaN"
                    Text="Registro de Venta"
                    Clicked="OnIrAVentana2Clicked"/>
                <Button
                    Margin="10"
                    Grid.Row="1"
                    Grid.Column="2"
                    WidthRequest="250"
                    HeightRequest="150"
                    Text="Historial Diario"
                    Clicked="OnIrAVentana3Clicked"/>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
